generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum StaffStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum ShopStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum ShopStaffRole {
  OWNER
  MANAGER
  CASHIER
  STAFF
}

enum ShopInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PlanStatus {
  ACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PaymentGatewayProvider {
  STRIPE
  OMISE
  XENDIT
  PAYPAL
  MANUAL
  LOCAL_BANK_TRANSFER
  PROMPTPAY
  PAYNOW
}

enum PaymentGatewayStatus {
  DRAFT
  ACTIVE
  DISABLED
}

enum ShippingZoneStatus {
  ACTIVE
  DISABLED
}

enum TaxProfileStatus {
  ACTIVE
  DISABLED
}

enum GovernanceActionCategory {
  ROUTINE_OPERATION
  STRATEGIC
  FINANCIAL
  LEGAL
  COMPLIANCE
  MODERATION
  POLICY
}

enum GovernanceRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GovernanceApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELED
  EXECUTED
}

model User {
  id                         String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                      String                   @db.VarChar(320)
  passwordHash               String                   @db.Text
  name                       String?                  @db.VarChar(160)
  status                     UserStatus               @default(ACTIVE)
  countryCode                String?                  @db.Char(2)
  localeCode                 String?                  @db.VarChar(35)
  preferredLocale            String?                  @db.VarChar(35)
  preferredCurrency          String?                  @db.Char(3)
  timeZone                   String                   @default("UTC") @db.VarChar(64)
  country                    Country?                 @relation(fields: [countryCode], references: [code], onDelete: SetNull)
  locale                     Locale?                  @relation(fields: [localeCode], references: [code], onDelete: SetNull)
  preferredLocaleRef         Locale?                  @relation("UserPreferredLocale", fields: [preferredLocale], references: [code], onDelete: SetNull)
  preferredCurrencyRef       Currency?                @relation(fields: [preferredCurrency], references: [code], onDelete: SetNull)
  roles                      UserRole[]
  sessions                   Session[]
  ownedShops                 Shop[]                   @relation("ShopOwner")
  shopStaff                  ShopStaff[]
  requestedGovernanceActions GovernanceActionReview[] @relation("GovernanceActionRequester")
  reviewedGovernanceActions  GovernanceActionReview[] @relation("GovernanceActionReviewer")
  createdAt                  DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime                 @updatedAt @db.Timestamptz(6)
  deletedAt                  DateTime?                @db.Timestamptz(6)

  @@index([status])
  @@index([countryCode])
  @@index([localeCode])
  @@index([preferredLocale])
  @@index([preferredCurrency])
  @@index([deletedAt])
  @@map("users")
}

model Language {
  code       String    @id @db.VarChar(12)
  name       String    @db.VarChar(120)
  nativeName String?   @db.VarChar(120)
  direction  String    @default("ltr") @db.VarChar(3)
  isActive   Boolean   @default(true)
  locales    Locale[]
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt  DateTime? @db.Timestamptz(6)

  @@index([isActive])
  @@index([deletedAt])
  @@map("languages")
}

model Locale {
  code                 String                @id @db.VarChar(35)
  languageCode         String                @db.VarChar(12)
  regionCode           String?               @db.Char(2)
  name                 String                @db.VarChar(120)
  nativeName           String?               @db.VarChar(120)
  isDefault            Boolean               @default(false)
  language             Language              @relation(fields: [languageCode], references: [code], onDelete: Restrict)
  defaultCountries     Country[]             @relation("CountryDefaultLocale")
  users                User[]
  preferredUsers       User[]                @relation("UserPreferredLocale")
  shops                Shop[]
  preferredShops       Shop[]                @relation("ShopPreferredLocale")
  shopTranslations     ShopTranslation[]
  productTranslations  ProductTranslation[]
  categoryTranslations CategoryTranslation[]
  createdAt            DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @db.Timestamptz(6)
  deletedAt            DateTime?             @db.Timestamptz(6)

  @@index([languageCode])
  @@index([regionCode])
  @@index([deletedAt])
  @@map("locales")
}

model Country {
  code                  String                @id @db.Char(2)
  name                  String                @db.VarChar(120)
  defaultCurrencyCode   String                @db.Char(3)
  defaultLocaleCode     String?               @db.VarChar(35)
  defaultTimeZone       String                @default("UTC") @db.VarChar(64)
  isActive              Boolean               @default(true)
  defaultCurrency       Currency              @relation(fields: [defaultCurrencyCode], references: [code], onDelete: Restrict)
  defaultLocale         Locale?               @relation("CountryDefaultLocale", fields: [defaultLocaleCode], references: [code], onDelete: SetNull)
  users                 User[]
  shops                 Shop[]
  taxProfiles           TaxProfile[]
  shippingZoneCountries ShippingZoneCountry[]
  createdAt             DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @db.Timestamptz(6)
  deletedAt             DateTime?             @db.Timestamptz(6)

  @@index([defaultCurrencyCode])
  @@index([defaultLocaleCode])
  @@index([isActive])
  @@index([deletedAt])
  @@map("countries")
}

model Currency {
  code                 String                 @id @db.Char(3)
  numericCode          String?                @db.Char(3)
  name                 String                 @db.VarChar(120)
  symbol               String?                @db.VarChar(16)
  decimalDigits        Int                    @default(2)
  isActive             Boolean                @default(true)
  defaultCountries     Country[]
  preferredUsers       User[]
  shops                Shop[]
  preferredShops       Shop[]                 @relation("ShopPreferredCurrency")
  plans                Plan[]
  invoices             Invoice[]
  exchangeRatesFrom    CurrencyExchangeRate[] @relation("ExchangeRateFromCurrency")
  exchangeRatesTo      CurrencyExchangeRate[] @relation("ExchangeRateToCurrency")
  productVariants      ProductVariant[]
  productVariantPrices ProductVariantPrice[]
  createdAt            DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime               @updatedAt @db.Timestamptz(6)
  deletedAt            DateTime?              @db.Timestamptz(6)

  @@index([isActive])
  @@index([deletedAt])
  @@map("currencies")
}

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String    @db.Text
  userAgent        String?   @db.Text
  ipAddress        String?   @db.VarChar(64)
  expiresAt        DateTime  @db.Timestamptz(6)
  revokedAt        DateTime? @db.Timestamptz(6)
  lastUsedAt       DateTime? @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt        DateTime? @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([deletedAt])
  @@map("sessions")
}

model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String     @db.VarChar(64)
  name        String     @db.VarChar(120)
  description String?    @db.Text
  users       UserRole[]
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?  @db.Timestamptz(6)

  @@index([deletedAt])
  @@map("roles")
}

model UserRole {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  roleId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  @@index([roleId])
  @@index([deletedAt])
  @@map("user_roles")
}

model Plan {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String          @db.VarChar(80)
  name          String          @db.VarChar(160)
  description   String?         @db.Text
  priceCents    Int
  currency      String          @default("USD") @db.Char(3)
  currencyRef   Currency        @relation(fields: [currency], references: [code], onDelete: Restrict)
  interval      BillingInterval
  status        PlanStatus      @default(ACTIVE)
  subscriptions Subscription[]
  createdAt     DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime?       @db.Timestamptz(6)

  @@index([status])
  @@index([currency])
  @@index([interval])
  @@index([deletedAt])
  @@map("plans")
}

model Subscription {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId             String             @db.Uuid
  planId             String             @db.Uuid
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime           @db.Timestamptz(6)
  currentPeriodEnd   DateTime           @db.Timestamptz(6)
  trialEndsAt        DateTime?          @db.Timestamptz(6)
  canceledAt         DateTime?          @db.Timestamptz(6)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  plan               Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices           Invoice[]
  createdAt          DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @db.Timestamptz(6)
  deletedAt          DateTime?          @db.Timestamptz(6)

  @@index([shopId, status])
  @@index([planId])
  @@index([currentPeriodEnd])
  @@index([deletedAt])
  @@map("subscriptions")
}

model Invoice {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId         String        @db.Uuid
  subscriptionId String?       @db.Uuid
  invoiceNumber  String        @db.VarChar(80)
  status         InvoiceStatus @default(DRAFT)
  subtotalCents  Int
  taxCents       Int           @default(0)
  totalCents     Int
  currency       String        @default("USD") @db.Char(3)
  currencyRef    Currency      @relation(fields: [currency], references: [code], onDelete: Restrict)
  dueAt          DateTime?     @db.Timestamptz(6)
  paidAt         DateTime?     @db.Timestamptz(6)
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?     @db.Timestamptz(6)

  @@unique([shopId, invoiceNumber])
  @@index([shopId, status])
  @@index([currency])
  @@index([subscriptionId])
  @@index([dueAt])
  @@index([deletedAt])
  @@map("invoices")
}

model Shop {
  id                      String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId                 String                        @db.Uuid
  name                    String                        @db.VarChar(160)
  slug                    String                        @db.VarChar(120)
  description             String?                       @db.Text
  logoUrl                 String?                       @db.Text
  bannerUrl               String?                       @db.Text
  contactEmail            String?                       @db.VarChar(320)
  contactPhone            String?                       @db.VarChar(40)
  status                  ShopStatus                    @default(ACTIVE)
  isPublic                Boolean                       @default(true)
  countryCode             String                        @default("US") @db.Char(2)
  localeCode              String                        @default("en-US") @db.VarChar(35)
  currencyCode            String                        @default("USD") @db.Char(3)
  preferredLocale         String?                       @db.VarChar(35)
  preferredCurrency       String?                       @db.Char(3)
  timeZone                String                        @default("UTC") @db.VarChar(64)
  owner                   User                          @relation("ShopOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  country                 Country                       @relation(fields: [countryCode], references: [code], onDelete: Restrict)
  locale                  Locale                        @relation(fields: [localeCode], references: [code], onDelete: Restrict)
  currency                Currency                      @relation(fields: [currencyCode], references: [code], onDelete: Restrict)
  preferredLocaleRef      Locale?                       @relation("ShopPreferredLocale", fields: [preferredLocale], references: [code], onDelete: SetNull)
  preferredCurrencyRef    Currency?                     @relation("ShopPreferredCurrency", fields: [preferredCurrency], references: [code], onDelete: SetNull)
  translations            ShopTranslation[]
  staff                   ShopStaff[]
  invitations             ShopInvitation[]
  subscriptions           Subscription[]
  invoices                Invoice[]
  categories              Category[]
  products                Product[]
  paymentGateways         PaymentGatewayConfiguration[]
  shippingZones           ShippingZone[]
  taxProfiles             TaxProfile[]
  governanceActionReviews GovernanceActionReview[]
  createdAt               DateTime                      @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime                      @updatedAt @db.Timestamptz(6)
  deletedAt               DateTime?                     @db.Timestamptz(6)

  @@index([ownerId])
  @@index([status])
  @@index([isPublic])
  @@index([countryCode])
  @@index([localeCode])
  @@index([currencyCode])
  @@index([preferredLocale])
  @@index([preferredCurrency])
  @@index([deletedAt])
  @@map("shops")
}

model GovernanceActionReview {
  id                String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String?                  @db.Uuid
  requestedByUserId String?                  @db.Uuid
  reviewedByUserId  String?                  @db.Uuid
  agentName         String                   @db.VarChar(120)
  category          GovernanceActionCategory
  riskLevel         GovernanceRiskLevel      @default(MEDIUM)
  status            GovernanceApprovalStatus @default(DRAFT)
  title             String                   @db.VarChar(200)
  recommendation    String                   @db.Text
  explanation       String                   @db.Text
  confidence        Int
  approvalReason    String?                  @db.Text
  rejectionReason   String?                  @db.Text
  metadata          Json?
  requestedAt       DateTime                 @default(now()) @db.Timestamptz(6)
  reviewedAt        DateTime?                @db.Timestamptz(6)
  executedAt        DateTime?                @db.Timestamptz(6)
  shop              Shop?                    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  requestedByUser   User?                    @relation("GovernanceActionRequester", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  reviewedByUser    User?                    @relation("GovernanceActionReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime                 @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime?                @db.Timestamptz(6)

  @@index([shopId, status])
  @@index([category, riskLevel])
  @@index([agentName])
  @@index([requestedByUserId])
  @@index([reviewedByUserId])
  @@index([deletedAt])
  @@map("governance_action_reviews")
}

model CurrencyExchangeRate {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  baseCurrencyCode  String    @db.Char(3)
  quoteCurrencyCode String    @db.Char(3)
  rate              Decimal   @db.Decimal(20, 10)
  provider          String    @db.VarChar(80)
  effectiveAt       DateTime  @db.Timestamptz(6)
  expiresAt         DateTime? @db.Timestamptz(6)
  baseCurrency      Currency  @relation("ExchangeRateFromCurrency", fields: [baseCurrencyCode], references: [code], onDelete: Restrict)
  quoteCurrency     Currency  @relation("ExchangeRateToCurrency", fields: [quoteCurrencyCode], references: [code], onDelete: Restrict)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime? @db.Timestamptz(6)

  @@index([baseCurrencyCode, quoteCurrencyCode, effectiveAt])
  @@index([provider])
  @@index([deletedAt])
  @@map("currency_exchange_rates")
}

model TaxProfile {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId             String           @db.Uuid
  countryCode        String           @db.Char(2)
  name               String           @db.VarChar(160)
  registrationNumber String?          @db.VarChar(120)
  rateBps            Int              @default(0)
  pricesIncludeTax   Boolean          @default(false)
  appliesToShipping  Boolean          @default(false)
  status             TaxProfileStatus @default(ACTIVE)
  shop               Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  country            Country          @relation(fields: [countryCode], references: [code], onDelete: Restrict)
  createdAt          DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @db.Timestamptz(6)
  deletedAt          DateTime?        @db.Timestamptz(6)

  @@index([shopId, status])
  @@index([countryCode])
  @@index([deletedAt])
  @@map("tax_profiles")
}

model ShippingZone {
  id        String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId    String                @db.Uuid
  name      String                @db.VarChar(160)
  status    ShippingZoneStatus    @default(ACTIVE)
  shop      Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  countries ShippingZoneCountry[]
  createdAt DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt DateTime              @updatedAt @db.Timestamptz(6)
  deletedAt DateTime?             @db.Timestamptz(6)

  @@index([shopId, status])
  @@index([deletedAt])
  @@map("shipping_zones")
}

model ShippingZoneCountry {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shippingZoneId String       @db.Uuid
  countryCode    String       @db.Char(2)
  shippingZone   ShippingZone @relation(fields: [shippingZoneId], references: [id], onDelete: Cascade)
  country        Country      @relation(fields: [countryCode], references: [code], onDelete: Restrict)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?    @db.Timestamptz(6)

  @@index([countryCode])
  @@index([deletedAt])
  @@map("shipping_zone_countries")
}

model PaymentGatewayConfiguration {
  id                  String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId              String                 @db.Uuid
  provider            PaymentGatewayProvider
  status              PaymentGatewayStatus   @default(DRAFT)
  displayName         String                 @db.VarChar(160)
  accountRef          String?                @db.VarChar(160)
  supportedCurrencies String[]               @default([])
  supportedCountries  String[]               @default([])
  credentialsRef      String?                @db.VarChar(240)
  metadata            Json?
  shop                Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt           DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime               @updatedAt @db.Timestamptz(6)
  deletedAt           DateTime?              @db.Timestamptz(6)

  @@index([shopId, provider, status])
  @@index([deletedAt])
  @@map("payment_gateway_configurations")
}

model ShopTranslation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId      String    @db.Uuid
  localeCode  String    @db.VarChar(35)
  name        String    @db.VarChar(160)
  description String?   @db.Text
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  locale      Locale    @relation(fields: [localeCode], references: [code], onDelete: Restrict)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  @@index([localeCode])
  @@index([deletedAt])
  @@map("shop_translations")
}

model ShopStaff {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId    String        @db.Uuid
  userId    String        @db.Uuid
  status    StaffStatus   @default(INVITED)
  role      ShopStaffRole @default(STAFF)
  title     String?       @db.VarChar(120)
  shop      Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @db.Timestamptz(6)
  deletedAt DateTime?     @db.Timestamptz(6)

  @@index([userId])
  @@index([shopId, status])
  @@index([shopId, role])
  @@index([deletedAt])
  @@map("shop_staff")
}

model ShopInvitation {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId    String               @db.Uuid
  email     String               @db.VarChar(320)
  role      ShopStaffRole
  status    ShopInvitationStatus @default(PENDING)
  expiresAt DateTime             @db.Timestamptz(6)
  shop      Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt DateTime             @updatedAt @db.Timestamptz(6)
  deletedAt DateTime?            @db.Timestamptz(6)

  @@index([shopId, status])
  @@index([email])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("shop_invitations")
}

model Category {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId       String                @db.Uuid
  parentId     String?               @db.Uuid
  name         String                @db.VarChar(160)
  slug         String                @db.VarChar(160)
  description  String?               @db.Text
  sortOrder    Int                   @default(0)
  shop         Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  parent       Category?             @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]            @relation("CategoryTree")
  products     Product[]
  translations CategoryTranslation[]
  createdAt    DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime              @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?             @db.Timestamptz(6)

  @@index([shopId, parentId])
  @@index([shopId, sortOrder])
  @@index([deletedAt])
  @@map("categories")
}

model CategoryTranslation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId  String    @db.Uuid
  localeCode  String    @db.VarChar(35)
  name        String    @db.VarChar(160)
  slug        String    @db.VarChar(160)
  description String?   @db.Text
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale      Locale    @relation(fields: [localeCode], references: [code], onDelete: Restrict)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  @@index([localeCode])
  @@index([deletedAt])
  @@map("category_translations")
}

model Product {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId       String               @db.Uuid
  categoryId   String?              @db.Uuid
  name         String               @db.VarChar(200)
  slug         String               @db.VarChar(200)
  description  String?              @db.Text
  status       ProductStatus        @default(DRAFT)
  shop         Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  translations ProductTranslation[]
  variants     ProductVariant[]
  images       ProductImage[]
  createdAt    DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?            @db.Timestamptz(6)

  @@index([shopId, status])
  @@index([categoryId])
  @@index([deletedAt])
  @@map("products")
}

model ProductTranslation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String    @db.Uuid
  localeCode  String    @db.VarChar(35)
  name        String    @db.VarChar(200)
  slug        String    @db.VarChar(200)
  description String?   @db.Text
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale      Locale    @relation(fields: [localeCode], references: [code], onDelete: Restrict)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  @@index([localeCode])
  @@index([deletedAt])
  @@map("product_translations")
}

model ProductVariant {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId      String                @db.Uuid
  sku            String                @db.VarChar(120)
  title          String                @db.VarChar(200)
  priceCents     Int
  currency       String                @default("USD") @db.Char(3)
  currencyRef    Currency              @relation(fields: [currency], references: [code], onDelete: Restrict)
  inventoryCount Int                   @default(0)
  isDefault      Boolean               @default(false)
  product        Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  prices         ProductVariantPrice[]
  createdAt      DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime              @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?             @db.Timestamptz(6)

  @@index([productId, isDefault])
  @@index([currency])
  @@index([deletedAt])
  @@map("product_variants")
}

model ProductVariantPrice {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productVariantId    String         @db.Uuid
  currencyCode        String         @db.Char(3)
  priceCents          Int
  compareAtPriceCents Int?
  productVariant      ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  currency            Currency       @relation(fields: [currencyCode], references: [code], onDelete: Restrict)
  createdAt           DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime       @updatedAt @db.Timestamptz(6)
  deletedAt           DateTime?      @db.Timestamptz(6)

  @@index([currencyCode])
  @@index([deletedAt])
  @@map("product_variant_prices")
}

model ProductImage {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String    @db.Uuid
  url       String    @db.Text
  altText   String?   @db.VarChar(200)
  sortOrder Int       @default(0)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  @@index([productId, sortOrder])
  @@index([deletedAt])
  @@map("product_images")
}
