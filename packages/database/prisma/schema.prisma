  @@map("payment_records")
}

model POSSession {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId      String           @db.Uuid
  cashierId   String           @db.Uuid
  status      POSSessionStatus @default(OPEN)
  openedAt    DateTime         @default(now()) @db.Timestamptz(6)
  closedAt    DateTime?        @db.Timestamptz(6)
  openingCash Int              @default(0)
  closingCash Int?
  shop        Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  cashier     User             @relation("POSSessionCashier", fields: [cashierId], references: [id], onDelete: Restrict)
  shifts      POSShift[]
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?        @db.Timestamptz(6)

  @@index([shopId, status])
  @@index([cashierId, status])
  @@index([deletedAt])
  @@map("pos_sessions")
}

model POSShift {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId       String         @db.Uuid
  posSessionId String         @db.Uuid
  cashierId    String         @db.Uuid
  status       POSShiftStatus @default(OPEN)
  openedAt     DateTime       @default(now()) @db.Timestamptz(6)
  closedAt     DateTime?      @db.Timestamptz(6)
  openingCash  Int            @default(0)
  closingCash  Int?
  shop         Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  posSession   POSSession     @relation(fields: [posSessionId], references: [id], onDelete: Cascade)
  cashier      User           @relation("POSShiftCashier", fields: [cashierId], references: [id], onDelete: Restrict)
  createdAt    DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?      @db.Timestamptz(6)

  @@index([shopId, status])
  @@index([cashierId, status])
  @@index([posSessionId])
  @@index([deletedAt])
  @@map("pos_shifts")
}
